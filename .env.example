PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here

ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Telegram Bot integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_BACKEND_URL=http://backend:8000
PUBLIC_BACKEND_URL=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_DEFAULT_VOICE=ErXwobaYiN019PkySvjV
TELEGRAM_DEFAULT_RATE=+0%
TELEGRAM_DEFAULT_PITCH=+0Hz
TELEGRAM_DEFAULT_SHOW_SUBTITLES=true
TELEGRAM_DEFAULT_SUBTITLE_STYLE=classic
TELEGRAM_LONG_POLL_TIMEOUT=30
TELEGRAM_JOB_TIMEOUT_SEC=1800
TELEGRAM_SCRIPT_DEFAULT_TONE=educativo viral
TELEGRAM_SCRIPT_DEFAULT_DURATION=60
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct

# Cache auto-cleanup
MAX_CACHE_SIZE_MB=800
MAX_FILE_AGE_DAYS=1
MAX_FILE_AGE_HOURS=12
CACHE_CLEANUP_INTERVAL_SECONDS=30

# Local script generation with Ollama + Qwen
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SCRIPT_MODEL=qwen2.5:7b-instruct

# Qwen reranker for video selection
ENABLE_QWEN_VIDEO_RERANK=true
OLLAMA_VIDEO_RERANK_MODEL=qwen2.5:7b-instruct
QWEN_VIDEO_RERANK_TOP_K=6
# Visual reranking (disabled by default - very slow, analyzes video frames with AI)
ENABLE_QWEN_VIDEO_VISUAL_RERANK=false
OLLAMA_VIDEO_VISION_MODEL=qwen2.5vl:7b
QWEN_VIDEO_VISUAL_TOP_K=2
QWEN_VIDEO_VISUAL_MAX_FRAMES=1
QWEN_VIDEO_VISUAL_WEIGHT=18
MIN_RELEVANCE_SCORE=0.22
MIN_RELEVANCE_SCORE_GLOBAL=0.16
NASA_INTRO_SKIP_SECONDS=2.0
ESA_INTRO_SKIP_SECONDS=2.0
